# Example local-testing config for saltcorn against Postgres / SQLite / MySQL.
# Copy to .env (which is gitignored) and edit:  cp .env.example .env
#
# NOT auto-loaded by saltcorn - source it first, then run the CLI:
#   source .env && node packages/saltcorn-cli/bin/saltcorn <command>
# See packages/mysql-backend/TESTING.md (or the @saltcorn/mysql-backend repo)
# for the full walkthrough: all 3 backends, .saltcorn config-file examples,
# and common commands.
#
# Exactly one of the three database blocks below should be active at a time -
# the others must stay fully commented out. connect.ts picks the backend in
# this order: DATABASE_URL (if set, wins outright and discards user/password/
# database) -> SQLITE_FILEPATH -> Postgres-style user+password+database. A
# stray uncommented var from another block can silently change which backend
# is used.
#
# The `unset` lines below clear everything first: re-sourcing this file in a
# shell that still has vars exported from a previous run would otherwise leave
# stale values active even after you comment them out (`source` only adds/
# overrides, it never unsets on its own).
unset DATABASE_URL SQLITE_FILEPATH SALTCORN_DB_DRIVER SALTCORN_DEFAULT_SCHEMA
unset PGHOST PGPORT PGUSER PGPASSWORD PGDATABASE

# Session signing secret. Any non-empty string works for local dev; a random
# one is generated (with a warning) if unset. Use a real secret in production.
export SALTCORN_SESSION_SECRET='hrh64b45b3'

############# SQLite (default: zero-config, no server needed) #############
export SQLITE_FILEPATH="$HOME/saltcorn_db.sqlite"

############# Postgres #############
# export PGHOST='localhost'
# export PGPORT='5432'
# export PGUSER='postgres'
# export PGPASSWORD='yourpassword'
# export PGDATABASE='saltcorn_pg_db'
# Equivalent single-var form (DATABASE_URL wins over the discrete PG* vars):
# export DATABASE_URL='postgresql://postgres:yourpassword@localhost:5432/saltcorn_pg_db'

############# MySQL (via @saltcorn/mysql-backend; must be installed) #############
# Set default_schema to match the database name - MySQL has no separate schema
# concept, so the driver uses the database as the tenant-less "root" namespace.
# export SALTCORN_DB_DRIVER='@saltcorn/mysql-backend'
# export PGHOST='localhost'
# export PGPORT='3306'
# export PGUSER='root'
# export PGPASSWORD='yourpassword'
# export PGDATABASE='saltcorn_mysql_db'
# export SALTCORN_DEFAULT_SCHEMA='saltcorn_mysql_db'
# Equivalent single-var form instead of the 5 PG* vars above:
# export SALTCORN_DB_DRIVER='@saltcorn/mysql-backend'
# export DATABASE_URL='mysql://root:yourpassword@localhost:3306/saltcorn_mysql_db'
# export SALTCORN_DEFAULT_SCHEMA='saltcorn_mysql_db'

############# Optional, any backend #############
# export SALTCORN_MULTI_TENANT='true'
# export SALTCORN_FILE_STORE="$HOME/saltcorn-filestore"
