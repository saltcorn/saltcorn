{
  "name": "@saltcorn/server",
  "version": "1.7.0-alpha.0",
  "description": "Server app for Saltcorn, open-source no-code platform",
  "homepage": "https://saltcorn.com",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "require": "./cjs/app.cjs",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./serve": {
      "types": "./dist/serve.d.ts",
      "require": "./cjs/serve.cjs",
      "import": "./dist/serve.js",
      "default": "./dist/serve.js"
    },
    "./restart_watcher": {
      "types": "./dist/restart_watcher.d.ts",
      "require": "./cjs/restart_watcher.cjs",
      "import": "./dist/restart_watcher.js",
      "default": "./dist/restart_watcher.js"
    },
    "./auth/testhelp": {
      "types": "./dist/auth/testhelp.d.ts",
      "require": "./cjs/auth/testhelp.cjs",
      "import": "./dist/auth/testhelp.js",
      "default": "./dist/auth/testhelp.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "cjs/**/*.cjs",
    "public/**/*",
    "locales/**/*",
    "help/**/*",
    "docs/**/*",
    "!dist/tsconfig.ref.tsbuildinfo",
    "!dist/tsconfig.tsbuildinfo"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1057.0",
    "@aws-sdk/s3-request-presigner": "3.1057.0",
    "@dr.pogodin/csurf": "1.15.0",
    "@saltcorn/admin-models": "1.7.0-alpha.0",
    "@saltcorn/base-plugin": "1.7.0-alpha.0",
    "@saltcorn/builder": "1.7.0-alpha.0",
    "@saltcorn/workflow-editor": "1.7.0-alpha.0",
    "@saltcorn/data": "1.7.0-alpha.0",
    "@saltcorn/filemanager": "1.7.0-alpha.0",
    "@saltcorn/markup": "1.7.0-alpha.0",
    "@saltcorn/plugins-loader": "1.7.0-alpha.0",
    "@saltcorn/sbadmin2": "1.7.0-alpha.0",
    "@socket.io/cluster-adapter": "^0.2.1",
    "@socket.io/sticky": "^1.0.1",
    "adm-zip": "0.5.16",
    "compression": "1.8.1",
    "connect-flash": "^0.1.1",
    "connect-pg-simple": "^9.0.1",
    "content-disposition": "^0.5.4",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.0",
    "cors": "2.8.5",
    "csv-stringify": "^6.5.2",
    "csvtojson": "^2.0.10",
    "dayjs": "^1.11.13",
    "dompurify": "3.4.11",
    "env-paths": "^2.2.1",
    "express": "^5.0.1",
    "express-fileupload": "^1.5.1",
    "express-promise-router": "^3.0.3",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "fs-extra": "^11.3.0",
    "greenlock": "^4.0.4",
    "greenlock-express": "^4.0.3",
    "helmet": "^8.0.0",
    "i18n": "^0.15.1",
    "jsdom": "26.1.0",
    "jsonwebtoken": "^9.0.2",
    "markdown-it": "^14.1.0",
    "moment": "^2.30.1",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "node-fetch": "2.6.9",
    "node-watch": "^0.7.4",
    "notp": "2.0.3",
    "npm-registry-fetch": "17.1.0",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-http-bearer": "^1.0.1",
    "passport-jwt": "4.0.1",
    "passport-totp": "0.0.2",
    "pg": "^8.13.1",
    "pluralize": "^8.0.0",
    "qrcode": "1.5.1",
    "resize-with-sharp-or-jimp": "0.1.9",
    "semver": "^7.6.3",
    "socket.io": "4.8.1",
    "systeminformation": "^5.25.11",
    "thirty-two": "1.0.2",
    "tmp-promise": "^3.0.3",
    "ua-parser-js": "^2.0.0",
    "underscore": "1.13.7",
    "uuid": "^11.0.5",
    "@saltcorn/db-common": "1.7.0-alpha.0",
    "web-push": "^3.6.7",
    "@saltcorn/types": "1.7.0-alpha.0"
  },
  "optionalDependencies": {
    "connect-sqlite3": "^0.9.15",
    "sd-notify": "^2.8.0"
  },
  "repository": "github:saltcorn/saltcorn",
  "devDependencies": {
    "supertest-fetch": "^2.0.0"
  },
  "scripts": {
    "dev": "nodemon index.js",
    "test": "cd dist && NODE_ENV=test node --require ../setup-jest-globals.cjs --require ../setup-test-schema.cjs --test --test-force-exit",
    "tsc": "tsc -p tsconfig.json",
    "clean": "rm -rf ./dist/*"
  },
  "publishConfig": {
    "access": "public"
  }
}