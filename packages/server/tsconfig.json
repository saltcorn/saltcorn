{
  "compilerOptions": {
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "./dist",
    "allowJs": true,
    "checkJs": false,
    "sourceMap": true,
    "composite": true,
    "declaration": true /* set to true by "composite" */,
    "declarationMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true /* set to true by "esModuleInterop" and "module" */,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    /* https://github.com/microsoft/TypeScript/wiki/Node-Target-Mapping */
    "lib": ["ES2021", "dom"],
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2021"
  },
  "include": ["**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "cjs",
    "public",
    "docs",
    "setup-jest-globals.cjs",
    "setup-test-schema.cjs"
  ]
}
