{
  "name": "@saltcorn/markup",
  "version": "1.7.0-alpha.0",
  "description": "Markup for Saltcorn, open-source no-code platform",
  "homepage": "https://saltcorn.com",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "test": "cd dist && node --test",
    "gen:tags": "node gen-tags.cjs",
    "pretsc": "node gen-tags.cjs",
    "tsc": "tsc -p tsconfig.json",
    "clean": "rm -rf ./dist/*",
    "build": "webpack --mode development --config webpack.config.cjs"
  },
  "author": "Tom Nielsen",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./layout": {
      "types": "./dist/layout.d.ts",
      "require": "./cjs/layout.cjs",
      "import": "./dist/layout.js",
      "default": "./dist/layout.js"
    },
    "./table": {
      "types": "./dist/table.d.ts",
      "require": "./cjs/table.cjs",
      "import": "./dist/table.js",
      "default": "./dist/table.js"
    },
    "./tabs": {
      "types": "./dist/tabs.d.ts",
      "require": "./cjs/tabs.cjs",
      "import": "./dist/tabs.js",
      "default": "./dist/tabs.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "require": "./cjs/builder.cjs",
      "import": "./dist/builder.js",
      "default": "./dist/builder.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "require": "./cjs/workflow.cjs",
      "import": "./dist/workflow.js",
      "default": "./dist/workflow.js"
    },
    "./mktag": {
      "types": "./dist/mktag.d.ts",
      "require": "./cjs/mktag.cjs",
      "import": "./dist/mktag.js",
      "default": "./dist/mktag.js"
    },
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "files": [
    "dist/**/*",
    "cjs/*.cjs",
    "webpack.config.cjs",
    "!dist/tsconfig.ref.tsbuildinfo"
  ],
  "dependencies": {
    "escape-html": "^1.0.3",
    "html-tags": "3.3.1",
    "xss": "^1.0.15"
  },
  "repository": "github:saltcorn/saltcorn",
  "devDependencies": {
    "@saltcorn/types": "1.7.0-alpha.0",
    "@saltcorn/db-common": "1.7.0-alpha.0",
    "@types/escape-html": "^1.0.4",
    "@types/estree": "^1.0.8",
    "@types/node": "^20.14.7",
    "typescript": "5.9.2",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}