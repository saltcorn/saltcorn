{
  "name": "@saltcorn/admin-models",
  "version": "1.7.0-alpha.0",
  "description": "models only required by the admin interface for Saltcorn, open-source no-code platform",
  "homepage": "https://saltcorn.com",
  "type": "module",
  "scripts": {
    "test": "cd dist && NODE_ENV=test node --require ../setup-test-schema.cjs --test --test-force-exit",
    "gen:cjs-shims": "node gen-cjs-shims.cjs",
    "pretsc": "node gen-cjs-shims.cjs",
    "tsc": "tsc -p tsconfig.json",
    "clean": "rm -rf ./dist/*"
  },
  "author": "Tom Nielsen",
  "license": "MIT",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./cjs/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "require": "./cjs/*.cjs",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "require": "./cjs/*.cjs",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "files": [
    "dist/**/*",
    "!dist/tsconfig.ref.tsbuildinfo",
    "cjs/**/*.cjs",
    "gen-cjs-shims.cjs"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "3.1057.0",
    "@aws-sdk/lib-storage": "3.1057.0",
    "@saltcorn/types": "1.7.0-alpha.0",
    "@saltcorn/markup": "1.7.0-alpha.0",
    "@saltcorn/db-common": "1.7.0-alpha.0",
    "@saltcorn/data": "1.7.0-alpha.0",
    "adm-zip": "0.5.16",
    "chaos-guinea-pig": "0.2.1",
    "csv-stringify": "^6.5.2",
    "csvtojson": "^2.0.10",
    "dateformat": "^4.6.3",
    "lodash": "^4.17.23",
    "node-fetch": "2.6.9",
    "ssh2-sftp-client": "11.0.0",
    "tmp-promise": "^3.0.3"
  },
  "repository": "github:saltcorn/saltcorn",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@saltcorn/sbadmin2": "1.7.0-alpha.0",
    "@types/adm-zip": "0.5.7",
    "@types/dateformat": "5.0.0",
    "@types/lodash": "4.14.182",
    "@types/node": "^20.14.7",
    "@types/node-fetch": "2.5.12",
    "@types/ssh2-sftp-client": "9.0.3",
    "@types/tmp": "^0.2.3",
    "typescript": "5.9.2"
  },
  "overrides": {
    "parse5": "7.2.1",
    "undici": "7.12.0",
    "parse5-htmlparser2-tree-adapter": "7.0.0"
  }
}