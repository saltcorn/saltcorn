{
  "name": "@saltcorn/plugins-loader",
  "version": "1.6.0",
  "description": "Saltcorn plugin loader",
  "homepage": "https://saltcorn.com",
  "type": "module",
  "scripts": {
    "test": "cd dist && NODE_ENV=test node --test --test-force-exit --test-concurrency=1",
    "gen:cjs-shims": "node gen-cjs-shims.cjs",
    "pretsc": "node gen-cjs-shims.cjs",
    "tsc": "tsc -p tsconfig.json",
    "clean": "rm -rf ./dist/*"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./cjs/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "require": "./cjs/*.cjs",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "require": "./cjs/*.cjs",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "files": [
    "dist/**/*",
    "cjs/**/*.cjs",
    "gen-cjs-shims.cjs"
  ],
  "dependencies": {
    "@saltcorn/data": "1.6.0",
    "env-paths": "^2.2.1",
    "npm-registry-fetch": "17.1.0",
    "https-proxy-agent": "^7.0.6",
    "fs-extra": "11.3.5",
    "semver": "^7.6.3",
    "tar": "^6.2.1",
    "tmp-promise": "^3.0.3"
  },
  "devDependencies": {
    "@saltcorn/db-common": "1.6.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.7",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "typescript": "5.9.2"
  },
  "author": "Christian Hugo",
  "license": "MIT",
  "repository": "github:saltcorn/saltcorn",
  "publishConfig": {
    "access": "public"
  }
}
