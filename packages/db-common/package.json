{
  "name": "@saltcorn/db-common",
  "version": "1.6.0",
  "description": "Db common structures for Saltcorn, open-source no-code platform",
  "homepage": "https://saltcorn.com",
  "scripts": {
    "test": "cd dist && node --test",
    "tsc": "tsc -p tsconfig.json",
    "clean": "rm -rf ./dist/*"
  },
  "main": "./dist/index.js",
  "author": "Tom Nielsen",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "files": [
    "dist/**/*",
    "!dist/tsconfig.ref.tsbuildinfo"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.7",
    "typescript": "5.9.2"
  },
  "repository": "github:saltcorn/saltcorn",
  "publishConfig": {
    "access": "public"
  }
}